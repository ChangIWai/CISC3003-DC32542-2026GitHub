Options -Indexes
DirectoryIndex index.php

<IfModule mod_rewrite.c>
    RewriteEngine On

    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    RewriteRule ^(?:index|home)\.php$ php/home/home.php [L,NC]
    RewriteRule ^(about|contact|services|health_ok)\.php$ php/home/$1.php [L,NC]
    RewriteRule ^(login|register|login_verify)\.php$ php/auth/$1.php [L,NC]
    RewriteRule ^(dashboard|dashboard_tiny|account|forum|rental_action)\.php$ php/app/$1.php [L,NC]
</IfModule>

# Block sensitive files (Apache 2.4 + 2.2 / LiteSpeed compatible)
<Files ".dashboard_fatal.log">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</Files>

<FilesMatch "^(\.env|\.env\..*|log\.txt|composer\.(json|lock)|package(-lock)?\.json|Dockerfile|\.dockerignore)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

<FilesMatch "\.(sql|md)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>
